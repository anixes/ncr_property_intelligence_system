# NCR Property Price Estimator - Environment Configuration

# API connection for the Streamlit frontend
# Inside Docker Compose, 'api' refers to the service name
API_BASE_URL=http://api:8000

# Registry context (used for building image URLs)
# This usually matches your 'user/repo'
GITHUB_REPOSITORY=anixes/ncr_property_price_estimation

# Tag used for images (defaults to latest if not set)
IMAGE_TAG=latest
